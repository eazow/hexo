<script>
(function () {
  var numberOfBanners = 10;
  var intervalMs = 5000;

  var layerA = document.querySelector('.banner-layer-a');
  var layerB = document.querySelector('.banner-layer-b');
  if (!layerA || !layerB) return;

  var urls = [];
  for (var i = 0; i < numberOfBanners; i++) {
    urls.push('/images/banner' + i + '.webp');
  }
  // shuffle so the slideshow order differs between visits
  for (var i = urls.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var tmp = urls[i];
    urls[i] = urls[j];
    urls[j] = tmp;
  }

  // preload every banner once so the browser caches them up front;
  // later switches then read from cache instead of firing new requests
  urls.forEach(function (url) {
    var img = new Image();
    img.src = url;
  });

  var layers = [layerA, layerB];
  var current = 0;
  var index = 0;

  function setLayer(layer, url) {
    layer.style.backgroundImage = "url('" + url + "')";
  }

  setLayer(layers[current], urls[index]);
  layers[current].classList.add('is-active');

  if (urls.length <= 1) return;

  setInterval(function () {
    var next = current === 0 ? 1 : 0;
    index = (index + 1) % urls.length;
    setLayer(layers[next], urls[index]);
    layers[next].classList.add('is-active');
    layers[current].classList.remove('is-active');
    current = next;
  }, intervalMs);
})();
</script>
